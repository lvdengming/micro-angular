{
  "name": "micro-angular",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "node scripts/launch.mjs --standalone && ng build",
    "build:micro": "node scripts/launch.mjs && node scripts/build-prepare.mjs && ng build micro-angular --configuration production",
    "ng": "ng",
    "serve": "node scripts/launch.mjs --standalone && ng serve --open",
    "serve:micro": "node scripts/launch.mjs && ng s --project micro-angular --disable-host-check --port 8001 --live-reload false",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "chalk": "^5.6.2",
    "rxjs": "~7.8.0",
    "single-spa": ">=4.0.0",
    "single-spa-angular": "9.2.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "18.0.0",
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.0",
    "dotenv": "^17.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-package": "^2.0.0",
    "style-loader": "^3.3.1",
    "typescript": "~5.5.2"
  },
  "ports": {
    "standalone": 4200,
    "micro": 8001
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "trailingComma": "all",
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-package"
    ]
  }
}
